# microCMS — Service domain (subdomain part of https://<service>.microcms.io)
MICROCMS_SERVICE_DOMAIN=

# microCMS — Read-only API key (Service > API key > "GET" only)
MICROCMS_API_KEY=

# Shared secret used to authenticate microCMS webhook -> /api/revalidate
# Set the same value as the "Secret" field in microCMS webhook settings.
REVALIDATE_SECRET=

# Optional — public site URL used by sitemap / OG tags
NEXT_PUBLIC_SITE_URL=https://example.com
